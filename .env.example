# SSH Tunnel
SSH_HOST=192.9.200.12
SSH_PORT=22
SSH_USERNAME=user_global@rrhhapp.cramer.cl
SSH_PASSWORD=your_ssh_password_here

# PostgreSQL (como se ve desde el servidor SSH)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rh_cramer
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# Buk API
BUK_API_KEY=your_buk_api_key_here
BUK_BASE_URL=https://demo.buk.cl

# Nivel de log: INFO (normal) | DEBUG (verbose, muestra cada paso)
LOG_LEVEL=INFO

# Valores por defecto para cargos no listados en config/roles.yaml
DEFAULT_ITEM_ID=1751
DEFAULT_AMOUNT=40000
DEFAULT_DESCRIPTION=movilizacion
